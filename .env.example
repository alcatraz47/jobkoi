JOBKOI_APP_NAME=Jobkoi API
JOBKOI_APP_ENV=local
JOBKOI_APP_HOST=127.0.0.1
JOBKOI_APP_PORT=8000
JOBKOI_APP_LOG_LEVEL=INFO
JOBKOI_DATABASE_URL=postgresql+psycopg://jobkoi:jobkoi@localhost:5432/jobkoi
JOBKOI_SQLALCHEMY_ECHO=false
JOBKOI_DOCUMENT_STORAGE_DIR=storage/documents
JOBKOI_IMPORT_STORAGE_DIR=storage/imports
JOBKOI_FRONTEND_API_TIMEOUT_SECONDS=180
JOBKOI_OLLAMA_BASE_URL=http://127.0.0.1:11434
JOBKOI_OLLAMA_MODEL=qwen3.5:4b
JOBKOI_OLLAMA_TIMEOUT_SECONDS=120
JOBKOI_OLLAMA_MAX_RETRIES=1
JOBKOI_PROFILE_IMPORT_AUTO_APPROVE_ENABLED=true
JOBKOI_PROFILE_IMPORT_AUTO_APPROVE_MIN_CONFIDENCE=94
JOBKOI_PROFILE_IMPORT_LLM_ENABLED=true
JOBKOI_PROFILE_IMPORT_LLM_MAX_INPUT_CHARS=16000
JOBKOI_PROFILE_IMPORT_LLM_SUPERVISOR_ENABLED=true
JOBKOI_PROFILE_IMPORT_LLM_SUPERVISOR_MAX_INPUT_CHARS=8000
